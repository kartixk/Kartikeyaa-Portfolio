PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Allowed origin for CORS during development (your Vite dev URL)
CORS_ORIGIN=http://localhost:8080

# Preferred email provider (works well on free hosting over HTTPS)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Portfolio Contact <noreply@your-domain.com>

# Where contact form submissions should be emailed
CONTACT_RECIPIENT=your-email@example.com
# Optional: multiple inboxes (comma-separated)
# CONTACT_RECIPIENTS=owner1@example.com,owner2@example.com
# Optional aliases supported by backend
# OWNER_EMAIL=your-email@example.com
# CONTACT_EMAIL=your-email@example.com

